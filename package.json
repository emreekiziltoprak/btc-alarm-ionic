{
  "name": "btc-alarm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "node scripts/dev-mobile.cjs",
    "dev:emulator": "node scripts/dev-emulator.cjs",
    "build": "vue-tsc -b && vite build",
    "build:prod": "vue-tsc -b && vite build --mode production",
    "preview": "vite preview",
    "android:open": "npx cap open android",
    "android:sync": "npx cap sync android",
    "android:run": "npx cap run android",
    "android:build": "npm run build:prod && npx cap sync android && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^8.0.1",
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.1",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@ionic/vue": "^8.7.17",
    "@ionic/vue-router": "^8.7.17",
    "apexcharts": "^5.3.6",
    "axios": "^1.13.2",
    "firebase": "^12.9.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "vue3-apexcharts": "^1.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  }
}
